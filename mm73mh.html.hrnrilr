<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>XTMODEPRO</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: sans-serif; }
        body { background: #1a1a1a; color: #fff; display: flex; flex-direction: column; align-items: center; padding: 20px; }
        
        h1 { font-size: 24px; color: #ff007f; margin-bottom: 20px; letter-spacing: 2px; }
        
        .menu { display: flex; gap: 10px; margin-bottom: 20px; width: 100%; max-width: 360px; }
        .btn { flex: 1; padding: 12px; border: 1px solid #333; background: #222; color: #888; font-weight: bold; cursor: pointer; border-radius: 8px; }
        .btn.active { background: #ff007f; color: #fff; border-color: #ff007f; }

        .card { background: #fff; color: #333; width: 100%; max-width: 360px; border-radius: 12px; padding: 20px; display: none; box-shadow: 0 10px 20px rgba(0,0,0,0.3); }
        .card.active { display: block; }

        .info { margin-bottom: 10px; font-size: 14px; }
        .label { color: #888; font-size: 11px; text-transform: uppercase; }
        .val { font-weight: bold; color: #111; }

        .scratch-box { position: relative; width: 100%; height: 65px; margin-top: 15px; background: #eee; border: 2px dashed #ff007f; border-radius: 8px; overflow: hidden; }
        .code { position: absolute; width: 100%; height: 100%; display: flex; justify-content: center; align-items: center; font-size: 18px; font-weight: bold; letter-spacing: 1px; color: #000; background: #fff; user-select: none; }
        canvas { position: absolute; top: 0; left: 0; width: 100%; height: 100%; cursor: pointer; z-index: 10; touch-action: none; }
        
        .status { text-align: center; font-size: 11px; color: #999; margin-top: 8px; font-style: italic; }
        .reset { margin-top: 30px; background: none; color: #555; border: none; font-size: 11px; cursor: pointer; text-decoration: underline; }
    </style>
</head>
<body>

    <h1>XTMODEPRO</h1>

    <div class="menu">
        <button class="btn active" id="b1" onclick="buka(1)">Voucher 1</button>
        <button class="btn" id="b2" onclick="buka(2)">Voucher 2</button>
    </div>

    <!-- VOUCHER 1 -->
    <div class="card active" id="v1">
        <div class="info"><div class="label">No. Seri</div><div class="val">310224936625</div></div>
        <div class="info"><div class="label">Masa Berlaku</div><div class="val">19/07/2027</div></div>
        <div class="scratch-box">
            <div class="code">8799 5831 6997 5723</div>
            <canvas id="c1"></canvas>
        </div>
        <div class="status" id="s1">Gosok layar di atas</div>
    </div>

    <!-- VOUCHER 2 -->
    <div class="card" id="v2">
        <div class="info"><div class="label">No. Seri</div><div class="val">800928674979</div></div>
        <div class="info"><div class="label">Info</div><div class="val" style="color:#ff007f">SP 61D (4 NOV 2026)</div></div>
        <div class="scratch-box">
            <div class="code">8799 5831 6997 5723</div>
            <canvas id="c2"></canvas>
        </div>
        <div class="status" id="s2">Gosok layar di atas</div>
    </div>

    <button class="reset" onclick="ulang()">Reset Gosokan</button>

    <script>
        function buka(num) {
            document.querySelectorAll('.card').forEach(c => c.classList.remove('active'));
            document.querySelectorAll('.btn').forEach(b => b.classList.remove('active'));
            document.getElementById('v' + num).classList.add('active');
            document.getElementById('b' + num).classList.add('active');
            buatGosokan(document.getElementById('c' + num), num);
        }

        function buatGosokan(canvas, id) {
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            canvas.width = canvas.parentElement.offsetWidth;
            canvas.height = canvas.parentElement.offsetHeight;

            if (localStorage.getItem('v_' + id) === 'true') {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                document.getElementById('s' + id).innerHTML = "✅ Sudah Terbuka";
                return;
            }

            ctx.fillStyle = '#b5b5b5';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = '#444';
            ctx.font = 'bold 12px sans-serif';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText('GOSOK DI SINI', canvas.width / 2, canvas.height / 2);

            let nempel = false;
            function gosok(e) {
                if (!nempel) return;
                const r = canvas.getBoundingClientRect();
                let x = (e.touches ? e.touches[0].clientX : e.clientX) - r.left;
                let y = (e.touches ? e.touches[0].clientY : e.clientY) - r.top;
                ctx.globalCompositeOperation = 'destination-out';
                ctx.beginPath(); ctx.arc(x, y, 18, 0, Math.PI * 2); ctx.fill();
            }

            function cek() {
                const data = ctx.getImageData(0, 0, canvas.width, canvas.height).data;
                let bolong = 0;
                for (let i = 3; i < data.length; i += 4) { if (data[i] === 0) bolong++; }
                if ((bolong / (data.length / 4)) * 100 > 40) {
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                    localStorage.setItem('v_' + id, 'true');
                    document.getElementById('s' + id).innerHTML = "✅ Sudah Terbuka";
                }
            }

            canvas.addEventListener('mousedown', () => nempel = true);
            canvas.addEventListener('mouseup', () => { nempel = false; cek(); });
            canvas.addEventListener('mousemove', gosok);
            canvas.addEventListener('touchstart', () => nempel = true);
            canvas.addEventListener('touchend', () => { nempel = false; cek(); });
            canvas.addEventListener('touchmove', gosok);
        }

        function ulang() {
            localStorage.clear();
            location.reload();
        }

        window.onload = () => buatGosokan(document.getElementById('c1'), 1);
    </script>
</body>
</html>
